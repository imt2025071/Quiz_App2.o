<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#27CCF5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Question"
            android:textSize="28sp"
            android:textColor="#333333"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:padding="20dp"
            android:elevation="4dp"
            android:layout_marginBottom="24dp">

            <EditText
                android:id="@+id/etQuestionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Type the question here..."
                android:textSize="18sp"
                android:padding="12dp"
                android:background="#27CCF5"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Options"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#888888"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etOptionA"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Option A"
                android:padding="12dp"
                android:background="#27CCF5"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/etOptionB"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Option B"
                android:padding="12dp"
                android:background="#27CCF5"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/etOptionC"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Option C"
                android:padding="12dp"
                android:background="#27CCF5"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/etOptionD"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Option D"
                android:padding="12dp"
                android:background="#27CCF5"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Correct Answer"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#888888"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etCorrectAnswer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. A, B, C, D or Exact Text"
                android:padding="12dp"
                android:background="#27CCF5"
                android:textColor="#005C8A"
                android:textStyle="bold" />

        </LinearLayout>

        <Button
            android:id="@+id/btnSaveQuestion"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save Question"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnFinishAdding"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Finish Adding Questions"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#888888"
            android:textColor="@android:color/white" />

    </LinearLayout>
</ScrollView>
